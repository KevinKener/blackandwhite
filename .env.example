# Supabase — use LOCAL values when developing (from `supabase start` output)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supavisor connection pooling URL (port 6543) — use this for DATABASE_URL,
# NOT the direct connection (port 5432). Required for Vercel serverless.
DATABASE_URL=postgresql://postgres:postgres@localhost:6543/postgres

# Express server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Admin panel (Vite — prefix VITE_ exposes to the browser)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=http://localhost:3000
VITE_CUSTOMER_PWA_URL=http://localhost:5174

# Customer PWA (Vite — port 5174)
# VITE_API_URL=http://localhost:3000  (same var, copy to client/customer/.env.local)
